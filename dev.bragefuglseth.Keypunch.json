{
   "id":"dev.bragefuglseth.Keypunch",
   "runtime":"org.gnome.Platform",
   "runtime-version":"50",
   "sdk":"org.gnome.Sdk",
   "sdk-extensions":[
      "org.freedesktop.Sdk.Extension.rust-stable"
   ],
   "command":"keypunch",
   "finish-args":[
      "--share=ipc",
      "--socket=fallback-x11",
      "--device=dri",
      "--socket=wayland",
      "--filesystem=xdg-run/app/com.discordapp.Discord:create"
   ],
   "build-options":{
      "append-path":"/usr/lib/sdk/rust-stable/bin"
   },
   "modules":[
      {
         "name":"keypunch",
         "builddir":true,
         "buildsystem":"meson",
         "config-opts":[
            "-Dbuildtype=release",
            "-Dsandboxed=true"
         ],
         "run-tests":true,
         "sources":[
            {
               "type":"git",
               "url":"https://github.com/bragefuglseth/keypunch.git",
               "tag":"v6.3",
               "commit":"901d3f9662e5d10ea00c6594ce5b38e2907a2177"
            },
            "cargo-sources.json"
         ]
      }
   ]
}
